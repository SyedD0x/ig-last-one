@"
# Dependencies
node_modules/

# Build outputs
.next/
out/
build/
dist/

# Environment files
.env
.env.local
.env*.local

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# OS metadata
.DS_Store
Thumbs.db

# IDE / editor
.vscode/
.idea/
*.swp
*.swo

# Misc
*.pem
*.neon?
"@ | Out-File -FilePath .gitignore -Encoding utf8 -Append